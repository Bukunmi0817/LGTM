{
  "annotations": { "list": [] },
  "description": "Unified observability — metric spike to correlated Loki logs to Tempo trace drill-down. The non-negotiable acceptance criterion. Audience: anyone debugging.",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Step 1 — Find the spike in metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Error rate over time. A spike here is your entry point. Select the time range of the spike, then look at Loki logs below.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "showPoints": "never", "spanNulls": false, "thresholdsStyle": { "mode": "line" } },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.05 }, { "color": "red", "value": 0.144 } ] },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "title": "Error rate — 5xx / total requests",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(http_requests_total{status=~\"5..\"}[5m]) / rate(http_requests_total[5m])", "legendFormat": "Error rate — {{ job }}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "p95 request latency. A spike here alongside errors confirms a service degradation. Use the time range of both spikes when searching Loki.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never", "spanNulls": false, "thresholdsStyle": { "mode": "line" } },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.3 }, { "color": "red", "value": 0.5 } ] },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "title": "p95 request latency (SLO threshold: 500ms)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p95 — {{ job }}", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 10,
      "title": "Step 2 — Correlate with Loki logs (trace IDs are clickable links to Tempo)",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Logs from the sample-app filtered by error level. Find log lines containing traceID — click the traceID link to open the trace in Tempo. This is the drill-down chain: metric spike → this log panel → Tempo trace.",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 10 },
      "id": 11,
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": false, "showCommonLabels": false, "showLabels": false, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true },
      "title": "Application logs — errors and warnings (click traceID to open in Tempo)",
      "type": "logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"sample-app\"} |= \"error\" or {job=\"sample-app\"} |= \"ERROR\" or {job=\"sample-app\"} |= \"warn\"",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 20,
      "title": "Step 3 — Find the trace in Tempo",
      "type": "row"
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "description": "Search for traces from the sample-app. Filter by service name and status=error to find the failing trace. Click any trace to see the full span waterfall — the slow or failing span identifies the exact line of code responsible.",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 23 },
      "id": 21,
      "options": {},
      "title": "Tempo trace search — sample-app errors",
      "type": "traces",
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "filters": [
            { "id": "service-name", "operator": "=", "scope": "resource", "tag": "service.name", "value": ["sample-app"], "valueType": "string" },
            { "id": "status", "operator": "=", "scope": "span", "tag": "status", "value": ["error"], "valueType": "string" }
          ],
          "limit": 20,
          "queryType": "traceql",
          "query": "{resource.service.name=\"sample-app\" && status=error}",
          "refId": "A",
          "tableType": "traces"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "id": 30,
      "title": "Four golden signals — traffic and saturation",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Request rate — the Traffic golden signal. How much demand is the system handling right now.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never", "spanNulls": false },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 36 },
      "id": 31,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "title": "Traffic — requests per second",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(http_requests_total[5m])", "legendFormat": "{{ job }} — {{ endpoint }}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Saturation — CPU and memory. How full is the service? High saturation explains high latency.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never", "spanNulls": false },
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 90 } ] },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 36 },
      "id": 32,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "title": "Saturation — CPU and memory %",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "(1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))) * 100", "legendFormat": "CPU %", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "legendFormat": "Memory %", "refId": "B" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["observability", "unified", "traces", "logs", "lgtm"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Unified Observability",
  "uid": "unified",
  "version": 1
}
