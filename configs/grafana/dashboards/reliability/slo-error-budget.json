{
  "annotations": { "list": [] },
  "description": "SLI vs SLO gauges, error budget remaining, burn rate time series. Audience: SRE team.",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "SLI vs SLO — current status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Availability SLO: 99.5% of HTTP probes must return 2xx over 30 days. Green = meeting SLO. Red = SLO violated.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "max": 100,
          "min": 99,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 99.5 }, { "color": "green", "value": 99.9 } ] },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 1 },
      "id": 2,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": true, "showThresholdMarkers": true },
      "title": "Availability SLI (SLO: 99.5%)",
      "type": "gauge",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "avg_over_time(probe_success[30d]) * 100", "legendFormat": "Availability %", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Latency SLO: 95% of requests must complete under 500ms. Green = meeting SLO.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "max": 100,
          "min": 90,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 95 }, { "color": "green", "value": 98 } ] },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 1 },
      "id": 3,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": true, "showThresholdMarkers": true },
      "title": "Latency SLI — requests under 500ms (SLO: 95%)",
      "type": "gauge",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(http_request_duration_seconds_bucket{le=\"0.5\"}[30d])) / sum(rate(http_request_duration_seconds_count[30d])) * 100", "legendFormat": "Requests under 500ms %", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Error Rate SLO: 99% of requests must be non-5xx. Green = meeting SLO.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "max": 100,
          "min": 98,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 99 }, { "color": "green", "value": 99.5 } ] },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "id": 4,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": true, "showThresholdMarkers": true },
      "title": "Error Rate SLI — non-5xx requests (SLO: 99%)",
      "type": "gauge",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "(1 - rate(http_requests_total{status=~\"5..\"}[30d]) / rate(http_requests_total[30d])) * 100", "legendFormat": "Success rate %", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 10,
      "title": "Error budget remaining",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Error budget = (1 - SLO) x window. Availability budget = 0.5% of 30 days = 216 minutes. This panel shows how much is left. Green = healthy. Red = exhausted.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 25 }, { "color": "yellow", "value": 50 }, { "color": "green", "value": 75 } ] },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 8 },
      "id": 11,
      "options": { "displayMode": "lcd", "minVizHeight": 10, "minVizWidth": 0, "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "showUnfilled": true },
      "title": "Error budget remaining (30-day window)",
      "type": "bargauge",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "((avg_over_time(probe_success[30d]) - 0.995) / (1 - 0.995)) * 100", "legendFormat": "Availability budget %", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "clamp_min(((1 - rate(http_requests_total{status=~\"5..\"}[30d]) / rate(http_requests_total[30d])) - 0.99) / (1 - 0.99) * 100, 0)", "legendFormat": "Error rate budget %", "refId": "B" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 20,
      "title": "Burn rate",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Burn rate = how fast error budget is being consumed. 1.0 = consuming at exactly the rate that exhausts budget at month end. 14.4 = exhausts budget in 1 hour (fast burn alert threshold). 5.0 = slow burn alert threshold.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never", "spanNulls": false },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 14.4 } ] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "id": 21,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "title": "Error budget burn rate — fast burn (1h) and slow burn (6h)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(http_requests_total{status=~\"5..\"}[1h]) / rate(http_requests_total[1h]) / 0.01", "legendFormat": "Burn rate (1h window)", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(http_requests_total{status=~\"5..\"}[6h]) / rate(http_requests_total[6h]) / 0.01", "legendFormat": "Burn rate (6h window)", "refId": "B" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 30,
      "title": "SLO compliance history",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Availability over the last 7 days and 30 days — are we meeting the 99.5% SLO?",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 99.5 }, { "color": "green", "value": 99.9 } ] },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 24 },
      "id": 31,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Availability — 7-day",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "avg_over_time(probe_success[7d]) * 100", "legendFormat": "7-day availability", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Availability over the last 30 days — the primary SLO measurement window.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 99.5 }, { "color": "green", "value": 99.9 } ] },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 24 },
      "id": 32,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Availability — 30-day",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "avg_over_time(probe_success[30d]) * 100", "legendFormat": "30-day availability", "refId": "A" }
      ]
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "tags": ["reliability", "slo", "error-budget", "lgtm"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "SLO and Error Budget",
  "uid": "slo-error-budget",
  "version": 1
}
