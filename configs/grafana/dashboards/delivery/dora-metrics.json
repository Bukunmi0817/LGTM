{
  "annotations": { "list": [] },
  "description": "DORA metrics — Deployment Frequency, Lead Time for Changes, Change Failure Rate, Mean Time to Restore. Audience: engineering leads.",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "DORA benchmark summary",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Deployment Frequency — how often code is deployed to production. Elite: multiple/day. High: daily-weekly. Medium: weekly-monthly. Low: monthly+.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "from": 1, "result": { "color": "green", "index": 0, "text": "ELITE" }, "to": 999 }, "type": "range" },
            { "options": { "from": 0.14, "result": { "color": "blue", "index": 1, "text": "HIGH" }, "to": 0.99 }, "type": "range" },
            { "options": { "from": 0.03, "result": { "color": "yellow", "index": 2, "text": "MEDIUM" }, "to": 0.13 }, "type": "range" },
            { "options": { "from": 0, "result": { "color": "red", "index": 3, "text": "LOW" }, "to": 0.02 }, "type": "range" }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.03 }, { "color": "blue", "value": 0.14 }, { "color": "green", "value": 1 } ] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name" },
      "title": "Deployment Frequency (per day)",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "increase(github_actions_workflow_run_total{conclusion=\"success\",name=~\".*[Dd]eploy.*|.*[Rr]elease.*\"}[1d])", "legendFormat": "Deployments today", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Lead Time for Changes — time from commit to production. Elite: under 1 hour. High: under 1 day. Medium: under 1 week. Low: over 1 week.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "from": 0, "result": { "color": "green", "index": 0, "text": "ELITE < 1h" }, "to": 3600 }, "type": "range" },
            { "options": { "from": 3601, "result": { "color": "blue", "index": 1, "text": "HIGH < 1d" }, "to": 86400 }, "type": "range" },
            { "options": { "from": 86401, "result": { "color": "yellow", "index": 2, "text": "MEDIUM < 1w" }, "to": 604800 }, "type": "range" },
            { "options": { "from": 604801, "result": { "color": "red", "index": 3, "text": "LOW > 1w" }, "to": 999999 }, "type": "range" }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "blue", "value": 3600 }, { "color": "yellow", "value": 86400 }, { "color": "red", "value": 604800 } ] },
          "unit": "s"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name" },
      "title": "Lead Time for Changes",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "github_actions_workflow_run_duration_seconds{name=~\".*[Dd]eploy.*\"}", "legendFormat": "Pipeline duration", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Change Failure Rate — percentage of deployments causing incidents. Elite: under 5%. High: under 10%. Medium: under 15%. Low: 15%+. SLO threshold: 15%.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "from": 0, "result": { "color": "green", "index": 0, "text": "ELITE" }, "to": 5 }, "type": "range" },
            { "options": { "from": 5.01, "result": { "color": "blue", "index": 1, "text": "HIGH" }, "to": 10 }, "type": "range" },
            { "options": { "from": 10.01, "result": { "color": "yellow", "index": 2, "text": "MEDIUM" }, "to": 15 }, "type": "range" },
            { "options": { "from": 15.01, "result": { "color": "red", "index": 3, "text": "LOW" }, "to": 100 }, "type": "range" }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "blue", "value": 5 }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 15 } ] },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name" },
      "title": "Change Failure Rate",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "(increase(github_actions_workflow_run_total{conclusion=\"failure\",name=~\".*[Dd]eploy.*\"}[7d]) / increase(github_actions_workflow_run_total{name=~\".*[Dd]eploy.*\"}[7d])) * 100", "legendFormat": "CFR %", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Mean Time to Restore — how long to recover from an incident. Elite: under 1 hour. High: under 1 day. Medium: under 1 week. Low: over 1 week.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "from": 0, "result": { "color": "green", "index": 0, "text": "ELITE < 1h" }, "to": 3600 }, "type": "range" },
            { "options": { "from": 3601, "result": { "color": "blue", "index": 1, "text": "HIGH < 1d" }, "to": 86400 }, "type": "range" },
            { "options": { "from": 86401, "result": { "color": "yellow", "index": 2, "text": "MEDIUM" }, "to": 604800 }, "type": "range" },
            { "options": { "from": 604801, "result": { "color": "red", "index": 3, "text": "LOW > 1w" }, "to": 999999 }, "type": "range" }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "blue", "value": 3600 }, { "color": "yellow", "value": 86400 }, { "color": "red", "value": 604800 } ] },
          "unit": "s"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name" },
      "title": "Mean Time to Restore",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "incident_mttr_seconds", "legendFormat": "MTTR", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 10,
      "title": "Deployment frequency trend",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Deployment frequency over time. Upward trend = improving. Sudden drops = process issues.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1, "showPoints": "never", "spanNulls": false },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 11,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "title": "Deployments per day (30d)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "increase(github_actions_workflow_run_total{conclusion=\"success\",name=~\".*[Dd]eploy.*\"}[1d])", "legendFormat": "Successful deployments", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "increase(github_actions_workflow_run_total{conclusion=\"failure\",name=~\".*[Dd]eploy.*\"}[1d])", "legendFormat": "Failed deployments", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Change Failure Rate trend over 30 days. Alert fires when CFR exceeds 15% (DORA Low threshold).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never", "spanNulls": false },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 15 } ] },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 12,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "title": "Change Failure Rate trend (7d rolling)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "(increase(github_actions_workflow_run_total{conclusion=\"failure\",name=~\".*[Dd]eploy.*\"}[7d]) / increase(github_actions_workflow_run_total{name=~\".*[Dd]eploy.*\"}[7d])) * 100", "legendFormat": "CFR %", "refId": "A" }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "tags": ["delivery", "dora", "lgtm"],
  "templating": { "list": [] },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "DORA Metrics",
  "uid": "dora-metrics",
  "version": 1
}
