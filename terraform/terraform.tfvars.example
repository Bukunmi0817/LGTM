# Copy this file to terraform.tfvars and fill in real values.
# Never commit terraform.tfvars to git — it contains secrets.

# ── AWS infrastructure ─────────────────────────────────────────────────────────
aws_region           = "us-east-1"
instance_type        = "t3.large"
ssh_public_key_path  = "~/.ssh/id_ed25519.pub"
ssh_private_key_path = "~/.ssh/id_ed25519"

# One CIDR per engineer — use /32 for individual IPs
engineer_ips = [
  "203.0.113.1/32",  # Engineer 1
  "203.0.113.2/32",  # Engineer 2
]
# run `curl  https://checkip.amazonaws.com` to get your IP.

# IP of the server running your application (the one being monitored)
app_server_ip = "203.0.113.10/32"

# ── Observability stack secrets ────────────────────────────────────────────────
slack_webhook_url      = "https://hooks.slack.com/services/YOUR/WEBHOOK/URL"
slack_channel          = "#social-badge-devops-alerts"
grafana_admin_password = "ChooseAStrongPassword123!"
duckdns_subdomain      = "adeshipo-lgtm"
duckdns_token          = "your-duckdns-token"
metrics_retention      = "15d"
logs_retention         = 360
