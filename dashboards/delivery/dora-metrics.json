{
  "title": "DORA Metrics",
  "uid": "dora-metrics",
  "tags": ["delivery", "dora", "cicd"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5m",
  "time": { "from": "now-30d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Deployment Frequency (deployments/day)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "increase(deployments_total[1d])",
        "legendFormat": "Deployments today"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 3 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 2,
      "title": "Deployment Frequency Classification",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "rate(deployments_total[7d]) * 86400",
        "legendFormat": "Deploys/day (7d avg)"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            { "options": { "from": 0,    "to": 0.03, "result": { "text": "Low (monthly)",   "color": "red"    } }, "type": "range" },
            { "options": { "from": 0.03, "to": 0.14, "result": { "text": "Medium (weekly)",  "color": "yellow" } }, "type": "range" },
            { "options": { "from": 0.14, "to": 1,    "result": { "text": "High (daily)",     "color": "blue"   } }, "type": "range" },
            { "options": { "from": 1,    "to": 9999,  "result": { "text": "Elite (multiple/day)", "color": "green" } }, "type": "range" }
          ]
        }
      },
      "options": { "colorMode": "background" }
    },
    {
      "id": 3,
      "title": "Change Failure Rate %",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "rate(deployments_failed_total[7d]) / rate(deployments_total[7d]) * 100",
        "legendFormat": "CFR %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      },
      "options": { "colorMode": "background" }
    },
    {
      "id": 4,
      "title": "MTTR (Mean Time to Restore)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "avg(mttr_seconds)",
        "legendFormat": "MTTR"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3600 },
              { "color": "red", "value": 86400 }
            ]
          }
        }
      },
      "options": { "colorMode": "background" }
    },
    {
      "id": 5,
      "title": "Deployment Frequency Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "increase(deployments_total[1d])",
        "legendFormat": "Deployments"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 6,
      "title": "Lead Time for Changes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "avg(lead_time_seconds)",
        "legendFormat": "Lead time"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
