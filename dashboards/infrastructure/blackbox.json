{
  "title": "Blackbox Exporter",
  "uid": "blackbox",
  "tags": ["infrastructure", "probing"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "60s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Probe Success (1=UP, 0=DOWN)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "probe_success",
        "legendFormat": "{{instance}}"
      }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ],
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": { "colorMode": "background" }
    },
    {
      "id": 2,
      "title": "HTTP Response Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "probe_http_duration_seconds",
        "legendFormat": "{{instance}} — {{phase}}"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 3,
      "title": "SSL Certificate Expiry (days remaining)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "(probe_ssl_earliest_cert_expiry - time()) / 86400",
        "legendFormat": "{{instance}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 14 },
              { "color": "green", "value": 30 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Probe Success Rate (1h)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "avg_over_time(probe_success[1h])",
        "legendFormat": "{{instance}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      }
    },
    {
      "id": 5,
      "title": "DNS Lookup Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "probe_dns_lookup_time_seconds",
        "legendFormat": "{{instance}}"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
